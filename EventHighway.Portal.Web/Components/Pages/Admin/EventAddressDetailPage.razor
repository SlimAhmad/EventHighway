@page "/admin/event-addresses/{AddressId:guid}"
@attribute [Authorize(Roles = "Administrators")]
@using System.Linq
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.EventAddresses
@using EventHighway.Portal.Web.Models.Views.EventListeners
@using EventHighway.Portal.Web.Models.Views.EventParticipants
@using EventHighway.Portal.Web.Services.Views.EventAddresses
@using EventHighway.Portal.Web.Services.Views.EventListeners
@using EventHighway.Portal.Web.Services.Views.EventParticipants
@inject IEventAddressesViewService AddressesViewService
@inject IEventListenersViewService ListenersViewService
@inject IEventParticipantsViewService ParticipantsViewService
@inject NavigationManager Navigation

<PageTitle>Event Address</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Event Address</h2>
    <a class="btn btn-outline-secondary btn-sm" href="admin/event-addresses">Back to list</a>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else if (address is not null)
{
    <Card>
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <span class="fw-semibold">@address.Name</span>
                <Button Color="danger" CssClass="btn-sm" OnClick="RequestDeleteAddress">
                    Delete
                </Button>
            </div>
        </HeaderContent>
        <ChildContent>
            @if (deleteError is not null)
            {
                <div class="alert alert-danger" role="alert">@deleteError</div>
            }
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@address.Id</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@address.Description</dd>
            </dl>
        </ChildContent>
    </Card>

    <Card CssClass="mt-4">
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <span class="fw-semibold">Event Listeners</span>
                <Button Color="primary" CssClass="btn-sm" OnClick="OpenRegisterListenerModal">
                    Register Listener
                </Button>
            </div>
        </HeaderContent>
        <ChildContent>
            @if (listenersError is not null)
            {
                <div class="alert alert-danger" role="alert">@listenersError</div>
            }
            else if (listeners.Count == 0)
            {
                <p class="text-body-secondary mb-0">No listeners registered for this address.</p>
            }
            else
            {
                <DataTable TItem="EventListenerView" Items="listeners" Columns="listenerColumns"
                           Searchable="false">
                    <RowActions Context="listener">
                        <Button Color="danger" CssClass="btn-sm"
                                OnClick="@(() => RequestDeleteListener(listener))">
                            Delete
                        </Button>
                    </RowActions>
                </DataTable>
            }
        </ChildContent>
    </Card>
}
else
{
    <div class="alert alert-warning" role="alert">Address not found.</div>
}

<Modal Title="Register Listener" Visible="showRegisterListenerModal" OnClose="CloseRegisterListenerModal">
    <ChildContent>
        @if (registerListenerError is not null)
        {
            <div class="alert alert-danger" role="alert">@registerListenerError</div>
        }
        <FormText Label="Name" @bind-Value="newListener.Name" />
        <FormText Label="Description" @bind-Value="newListener.Description" />
        <FormText Label="Handler Id" @bind-Value="newListenerHandlerId"
                  Placeholder="00000000-0000-0000-0000-000000000000" />
        <FormText Label="Handler Name" @bind-Value="newListener.HandlerName" />

        <div class="mb-3">
            <label class="form-label">Participant</label>
            <select class="form-select" value="@newListenerParticipantId"
                    @onchange="e => { newListenerParticipantId = e.Value?.ToString() ?? string.Empty; }">
                <option value="">(none)</option>
                @foreach (EventParticipantView participant in participants)
                {
                    <option value="@participant.Id">@participant.Name</option>
                }
            </select>
        </div>

        <FormText Label="Promoted Properties" @bind-Value="newListener.PromotedProperties" />
        <FormText Label="Filter Criteria" @bind-Value="newListener.FilterCriteria" />
    </ChildContent>
    <FooterContent>
        <Button Color="secondary" OnClick="CloseRegisterListenerModal">Cancel</Button>
        <Button Color="primary" OnClick="SubmitRegisterListenerAsync">Save</Button>
    </FooterContent>
</Modal>

<ConfirmDialog Visible="confirmVisible"
               Title="Confirm delete"
               Message="@confirmMessage"
               ConfirmText="OK"
               CancelText="Cancel"
               OnConfirm="ConfirmYesAsync"
               OnCancel="ConfirmNo" />

@code {
    [Parameter]
    public Guid AddressId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private EventAddressView? address;

    private List<EventListenerView> listeners = new();
    private string? listenersError;
    private List<DataTableColumn<EventListenerView>> listenerColumns = new();

    private bool showRegisterListenerModal;
    private string? registerListenerError;
    private EventListenerView newListener = new();
    private string? newListenerHandlerId;
    private string newListenerParticipantId = string.Empty;
    private List<EventParticipantView> participants = new();

    private string? deleteError;

    private bool confirmVisible;
    private string? confirmMessage;
    private Func<Task>? pendingConfirm;

    protected override async Task OnInitializedAsync()
    {
        listenerColumns = new List<DataTableColumn<EventListenerView>>
        {
            new DataTableColumn<EventListenerView> { Title = "Id", Value = l => l.Id },
            new DataTableColumn<EventListenerView> { Title = "Name", Value = l => l.Name },
            new DataTableColumn<EventListenerView> { Title = "Description", Value = l => l.Description },
            new DataTableColumn<EventListenerView> { Title = "Handler", Value = l => l.HandlerName },
        };

        try
        {
            var addresses = await AddressesViewService.RetrieveAllAddressesAsync();
            address = addresses.FirstOrDefault(item => item.Id == AddressId);

            if (address is not null)
            {
                participants = await ParticipantsViewService.RetrieveAllParticipantsAsync();
                await LoadListenersAsync();
            }
        }
        catch
        {
            errorMessage = "Unable to load this address. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadListenersAsync()
    {
        try
        {
            listeners = await ListenersViewService.RetrieveListenersByAddressAsync(AddressId);
            listenersError = null;
        }
        catch
        {
            listenersError = "Unable to load listeners.";
        }
    }

    private void OpenRegisterListenerModal()
    {
        newListener = new EventListenerView { EventAddressV2Id = AddressId };
        newListenerHandlerId = null;
        newListenerParticipantId = string.Empty;
        registerListenerError = null;
        showRegisterListenerModal = true;
    }

    private void CloseRegisterListenerModal() =>
        showRegisterListenerModal = false;

    private async Task SubmitRegisterListenerAsync()
    {
        if (!Guid.TryParse(newListenerHandlerId, out Guid handlerId))
        {
            registerListenerError = "Handler Id must be a valid GUID.";
            return;
        }

        newListener.HandlerId = handlerId;

        newListener.EventParticipantV2Id =
            Guid.TryParse(newListenerParticipantId, out Guid participantId)
                ? participantId
                : null;

        try
        {
            await ListenersViewService.RegisterListenerAsync(newListener);
            showRegisterListenerModal = false;
            await LoadListenersAsync();
        }
        catch
        {
            registerListenerError = "Unable to register the listener. Please try again.";
        }
    }

    private void RequestDeleteListener(EventListenerView listener) =>
        RequestConfirm(
            "Deleting this listener is permanent and cannot be undone.",
            () => DeleteListenerAsync(listener.Id));

    private async Task DeleteListenerAsync(Guid listenerId)
    {
        try
        {
            await ListenersViewService.RemoveListenerByIdAsync(listenerId);
            await LoadListenersAsync();
        }
        catch
        {
            listenersError =
                "Unable to delete this listener. It may still have events associated with it.";
        }
    }

    private void RequestDeleteAddress() =>
        RequestConfirm(
            "Deleting this address is permanent and cannot be undone.",
            DeleteAddressAsync);

    private async Task DeleteAddressAsync()
    {
        try
        {
            await AddressesViewService.RemoveAddressByIdAsync(AddressId);
            Navigation.NavigateTo("admin/event-addresses");
        }
        catch
        {
            deleteError =
                "Unable to delete this address. It may still have events or listeners associated with it.";
        }
    }

    private void RequestConfirm(string message, Func<Task> action)
    {
        confirmMessage = message;
        pendingConfirm = action;
        confirmVisible = true;
    }

    private async Task ConfirmYesAsync()
    {
        confirmVisible = false;
        Func<Task>? action = pendingConfirm;
        pendingConfirm = null;

        if (action is not null)
        {
            await action();
        }
    }

    private void ConfirmNo()
    {
        confirmVisible = false;
        pendingConfirm = null;
    }
}
