@page "/admin/event-archives/{EventArchiveId:guid}"
@attribute [Authorize(Roles = "Administrators")]
@using System.Collections.Generic
@using System.Linq
@using System.Text.Json
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.EventArchives
@using EventHighway.Portal.Web.Models.Views.ListenerEventArchives
@using EventHighway.Portal.Web.Services.Views.EventArchives
@using EventHighway.Portal.Web.Services.Views.ListenerEventArchives
@using EventHighway.Portal.Web.Services.Views.Replays
@inject IEventArchivesViewService EventArchivesViewService
@inject IListenerEventArchivesViewService ListenerEventArchivesViewService
@inject IReplayViewService ReplayViewService

<PageTitle>Archived Event</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Archived Event</h2>
    <a class="btn btn-outline-secondary btn-sm" href="admin/event-archives">Back to list</a>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else if (eventArchive is not null)
{
    <Card>
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <span class="fw-semibold">Archived Event</span>
                <span class="badge @StatusCssClass">@eventArchive.Status</span>
            </div>
        </HeaderContent>
        <ChildContent>
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@eventArchive.Id</dd>

                <dt class="col-sm-3">Event Name</dt>
                <dd class="col-sm-9">@DisplayOrDash(eventArchive.EventName)</dd>

                <dt class="col-sm-3">Content</dt>
                <dd class="col-sm-9">
                    @if (string.IsNullOrWhiteSpace(eventArchive.Content))
                    {
                        <span>—</span>
                    }
                    else
                    {
                        <Button Color="outline-primary" CssClass="btn-sm"
                                OnClick="() => showContent = true">
                            View Content
                        </Button>
                    }
                </dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@eventArchive.Type</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@eventArchive.Status</dd>

                <dt class="col-sm-3">Retries Left</dt>
                <dd class="col-sm-9">@eventArchive.RemainingRetryAttempts</dd>

                <dt class="col-sm-3">Event Address Id</dt>
                <dd class="col-sm-9">@eventArchive.EventAddressId</dd>

                <dt class="col-sm-3">Event Address</dt>
                <dd class="col-sm-9">@DisplayOrDash(eventArchive.EventAddressName)</dd>

                <dt class="col-sm-3">Participant Id</dt>
                <dd class="col-sm-9">@(eventArchive.ParticipantId?.ToString() ?? "—")</dd>

                <dt class="col-sm-3">Scheduled</dt>
                <dd class="col-sm-9">@(eventArchive.ScheduledDate?.ToString("u") ?? "—")</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@eventArchive.CreatedDate.ToString("u")</dd>

                <dt class="col-sm-3">Archived</dt>
                <dd class="col-sm-9">@eventArchive.ArchivedDate.ToString("u")</dd>
            </dl>
        </ChildContent>
    </Card>

    <Card CssClass="mt-4">
        <HeaderContent>
            <span class="fw-semibold">Dispatched listener events</span>
        </HeaderContent>
        <ChildContent>
            @if (replayMessage is not null)
            {
                <div class="alert @replayAlertClass" role="alert">@replayMessage</div>
            }
            @if (listenerEventArchives.Count == 0)
            {
                <p class="text-body-secondary mb-0">No events dispatched.</p>
            }
            else
            {
                <DataTable TItem="ListenerEventArchiveView" Items="FilteredListenerEventArchives"
                           Columns="listenerColumns" Searchable="true"
                           RowClass="@(a => a.Status == "Success" ? "table-success"
                               : a.Status == "Error" ? "table-danger"
                               : null)">
                    <ExtraFilters>
                        <select class="form-select w-auto" value="@selectedListenerStatus"
                                @onchange="e => { selectedListenerStatus = e.Value?.ToString() ?? string.Empty; }">
                            <option value="">All Statuses</option>
                            <option value="Pending">Pending</option>
                            <option value="Success">Success</option>
                            <option value="Error">Error</option>
                        </select>
                    </ExtraFilters>
                    <RowActions Context="archiveRow">
                        <Button Color="primary" CssClass="btn-sm"
                                Disabled="@isReplaying"
                                OnClick="@(() => RequestReplay(archiveRow))">
                            Replay
                        </Button>
                    </RowActions>
                </DataTable>
            }
        </ChildContent>
    </Card>

    <ConfirmDialog Visible="confirmReplayVisible"
                   Title="Confirm replay"
                   Message="Are you sure you want to replay this item? Be aware that replayed items will not be subject to loop detection!"
                   ConfirmText="OK"
                   CancelText="Cancel"
                   OnConfirm="ConfirmReplayAsync"
                   OnCancel="@(() => confirmReplayVisible = false)" />

    <Modal Title="Event Content" Size="xl" Scrollable="true"
           Visible="showContent" OnClose="() => showContent = false">
        <ChildContent>
            <div class="overflow-auto">
                <pre class="mb-0">@FormattedContent</pre>
            </div>
        </ChildContent>
        <FooterContent>
            <Button Color="secondary" OnClick="() => showContent = false">Close</Button>
        </FooterContent>
    </Modal>
}
else
{
    <div class="alert alert-warning" role="alert">Archived event not found.</div>
}

@code {
    [Parameter]
    public Guid EventArchiveId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private EventArchiveView? eventArchive;
    private List<ListenerEventArchiveView> listenerEventArchives = new();
    private List<DataTableColumn<ListenerEventArchiveView>> listenerColumns = new();
    private string selectedListenerStatus = string.Empty;
    private bool showContent;
    private bool isReplaying;
    private string? replayMessage;
    private string replayAlertClass = "alert-info";
    private bool confirmReplayVisible;
    private ListenerEventArchiveView? pendingReplayRow;

    private List<ListenerEventArchiveView> FilteredListenerEventArchives =>
        string.IsNullOrEmpty(selectedListenerStatus)
            ? listenerEventArchives
            : listenerEventArchives.Where(l => l.Status == selectedListenerStatus).ToList();

    // Pretty-prints the payload as indented JSON; falls back to the raw string when it
    // isn't valid JSON so non-JSON content is still viewable.
    private string FormattedContent
    {
        get
        {
            string content = eventArchive?.Content ?? string.Empty;

            if (string.IsNullOrWhiteSpace(content))
            {
                return string.Empty;
            }

            try
            {
                using JsonDocument document = JsonDocument.Parse(content);

                return JsonSerializer.Serialize(
                    document.RootElement,
                    new JsonSerializerOptions { WriteIndented = true });
            }
            catch (JsonException)
            {
                return content;
            }
        }
    }

    private string StatusCssClass =>
        eventArchive?.Status switch
        {
            "Active" => "text-bg-success",
            "Quarantined" => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    protected override async Task OnInitializedAsync()
    {
        listenerColumns = new List<DataTableColumn<ListenerEventArchiveView>>
        {
            new DataTableColumn<ListenerEventArchiveView> { Title = "Id", Value = a => a.Id },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Status",
                Value = a => a.Status,
                CellTemplate = a =>
                    @<span class="badge @(a.Status == "Success" ? "text-bg-success"
                        : a.Status == "Error" ? "text-bg-danger"
                        : "text-bg-secondary")">@a.Status</span>
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Response Code", Value = a => a.ResponseCode
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Response Message", Value = a => a.ResponseMessage
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Listener", Value = a => a.EventListenerId
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Listener Name", Value = a => a.ListenerName ?? "—"
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Archived", Value = a => a.ArchivedDate.ToString("u")
            },
        };

        try
        {
            eventArchive =
                await EventArchivesViewService.RetrieveEventArchiveByIdAsync(EventArchiveId);

            if (eventArchive is not null)
            {
                listenerEventArchives =
                    await ListenerEventArchivesViewService
                        .RetrieveListenerEventArchivesByEventArchiveIdAsync(EventArchiveId);
            }
        }
        catch
        {
            errorMessage = "Unable to load this archived event. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RequestReplay(ListenerEventArchiveView archiveRow)
    {
        pendingReplayRow = archiveRow;
        confirmReplayVisible = true;
    }

    private async Task ConfirmReplayAsync()
    {
        confirmReplayVisible = false;

        if (pendingReplayRow is null)
        {
            return;
        }

        await ReplayListenerEventAsync(pendingReplayRow);
        pendingReplayRow = null;
    }

    private async Task ReplayListenerEventAsync(ListenerEventArchiveView archiveRow)
    {
        isReplaying = true;
        replayMessage = null;

        try
        {
            await ReplayViewService.ReplayListenerEventArchiveAsync(
                eventV2Id: archiveRow.EventArchiveV2Id,
                eventAddressId: archiveRow.EventAddressId,
                eventListenerId: archiveRow.EventListenerId);

            replayAlertClass = "alert-success";

            replayMessage =
                $"Replay queued for {archiveRow.ListenerName ?? archiveRow.EventListenerId.ToString()}.";
        }
        catch
        {
            replayAlertClass = "alert-danger";
            replayMessage = "Unable to replay this listener event. Please try again.";
        }
        finally
        {
            isReplaying = false;
        }
    }

    private static string DisplayOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;
}
