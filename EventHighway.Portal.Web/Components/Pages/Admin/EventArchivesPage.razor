@page "/admin/event-archives"
@attribute [Authorize(Roles = "Administrators")]
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.EventArchives
@using EventHighway.Portal.Web.Services.Views.EventArchives
@inject IEventArchivesViewService EventArchivesViewService
@inject NavigationManager Navigation

<PageTitle>Archived Events</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Archived Events</h2>
</div>

<p class="text-body-secondary">
    Archived event maintenance. Live archive counts are shown on the Health Dashboard.
</p>

@if (message is not null)
{
    <div class="alert @alertClass" role="alert">@message</div>
}

<Card>
    <HeaderContent>
        <span class="fw-semibold">Purge old events</span>
    </HeaderContent>
    <ChildContent>
        <p class="text-body-secondary">
            Permanently remove archived events older than the chosen date.
        </p>
        <div class="d-flex flex-wrap align-items-end gap-3">
            <div style="min-width: 14rem;">
                <FormDate Label="Purge events older than" @bind-Value="purgeOlderThan" />
            </div>
            <div class="mb-3">
                <Button Color="danger" OnClick="RequestPurge"
                        Disabled="@(isWorking || purgeOlderThan is null)">
                    Purge
                </Button>
            </div>
        </div>
    </ChildContent>
</Card>

<ConfirmDialog Visible="confirmVisible"
               Title="Confirm purge"
               Message="@confirmMessage"
               ConfirmText="OK"
               CancelText="Cancel"
               OnConfirm="PurgeAsync"
               OnCancel="@(() => confirmVisible = false)" />

@if (isLoading)
{
    <Spinner />
}
else if (listErrorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@listErrorMessage</div>
}
else
{
    <Card CssClass="mt-4">
        <DataTable TItem="EventArchiveView" Items="eventArchives"
                   Columns="columns" Searchable="true">
            <RowActions Context="eventArchive">
                <Button Color="primary" CssClass="btn-sm"
                        OnClick="@(() => ViewArchive(eventArchive.Id))">
                    VIEW
                </Button>
            </RowActions>
        </DataTable>
    </Card>
}

@code {
    private bool isWorking;
    private string? message;
    private string alertClass = "alert-info";

    private DateTimeOffset? purgeOlderThan;
    private bool confirmVisible;
    private string? confirmMessage;

    private bool isLoading = true;
    private string? listErrorMessage;
    private List<EventArchiveView> eventArchives = new();
    private List<DataTableColumn<EventArchiveView>> columns = new();

    protected override async Task OnInitializedAsync()
    {
        columns = new List<DataTableColumn<EventArchiveView>>
        {
            new DataTableColumn<EventArchiveView> { Title = "Id", Value = a => a.Id },
            new DataTableColumn<EventArchiveView> { Title = "Event Name", Value = a => a.EventName },
            new DataTableColumn<EventArchiveView> { Title = "Content", Value = a => a.Content },
            new DataTableColumn<EventArchiveView> { Title = "Type", Value = a => a.Type },
            new DataTableColumn<EventArchiveView> { Title = "Status", Value = a => a.Status },
            new DataTableColumn<EventArchiveView>
            {
                Title = "Archived", Value = a => a.ArchivedDate.ToString("u")
            },
        };

        try
        {
            eventArchives =
                await EventArchivesViewService.RetrieveAllEventArchivesAsync();
        }
        catch
        {
            listErrorMessage = "Unable to load archived events. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewArchive(Guid eventArchiveId) =>
        Navigation.NavigateTo($"/admin/event-archives/{eventArchiveId}");

    private void RequestPurge()
    {
        if (purgeOlderThan is null)
        {
            return;
        }

        confirmMessage =
            $"Purge all archived events created before {purgeOlderThan:yyyy-MM-dd}? This cannot be undone.";

        confirmVisible = true;
    }

    private async Task PurgeAsync()
    {
        confirmVisible = false;
        isWorking = true;
        message = null;

        try
        {
            await EventArchivesViewService.PurgeArchivesOlderThanAsync(purgeOlderThan!.Value);
            alertClass = "alert-success";
            message = "Old archived events purged.";
        }
        catch
        {
            alertClass = "alert-danger";
            message = "Unable to purge archived events. Please try again.";
        }
        finally
        {
            isWorking = false;
        }
    }
}
