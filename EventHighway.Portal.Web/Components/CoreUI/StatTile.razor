@namespace EventHighway.Portal.Web.Components.CoreUI

<div class="stat-tile card @VariantCssClass">
    <div class="card-body p-3">
        @if (Icon is not null)
        {
            <i class="@Icon mb-2"></i>
        }
        <div class="fs-4 fw-semibold">@Value</div>
        <div class="text-uppercase small">@Label</div>
    </div>
</div>
