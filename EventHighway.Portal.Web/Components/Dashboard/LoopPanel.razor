@namespace EventHighway.Portal.Web.Components.Dashboard
@inherits PeriodAwarePanelBase
@using System.Linq
@using EventHighway.Core.Models.Coordinations.HealthChecks.V2
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Services.Views.HealthDashboards
@inject IHealthViewService HealthViewService

<Card CssClass="mb-4">
    <HeaderContent>
        <div class="d-flex justify-content-between align-items-center w-100 flex-wrap gap-2">
            <span class="fw-semibold">Loop Detection</span>
            <PeriodNavigator Period="EffectivePeriod" WindowStart="EffectiveWindowStart"
                             Disabled="NavDisabled" CanGoNext="CanGoNext"
                             PeriodChanged="OnPeriodChanged" PreviousRequested="OnPrevious"
                             NextRequested="OnNext" CurrentRequested="OnCurrent" />
        </div>
    </HeaderContent>
    <ChildContent>
        @if (isLoading)
        {
            <Spinner />
        }
        else if (errorMessage is not null)
        {
            <div class="alert alert-danger mb-0" role="alert">@errorMessage</div>
        }
        else if (summary is not null)
        {
            <div class="row mb-3">
                <div class="col"><StatTile Variant="StatTileVariant.Red" Value="@summary.TotalActiveQuarantined.ToString()" Label="Active Quarantined" /></div>
                <div class="col"><StatTile Variant="StatTileVariant.Na" Value="@summary.TotalInWindow.ToString()" Label="In Window" /></div>
            </div>
            @if (labels.Count > 0)
            {
                <Chart ChartType="bar" Labels="labels" Datasets="datasets" Height="220" />
            }
            <DataTable TItem="LoopDetailV2" Items="details" Columns="columns" Searchable="false" />
        }
    </ChildContent>
</Card>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private LoopDetectionSummaryV2? summary;
    private List<LoopDetailV2> details = new();
    private List<string> labels = new();
    private List<ChartDataset> datasets = new();

    private readonly List<DataTableColumn<LoopDetailV2>> columns = new()
    {
        new DataTableColumn<LoopDetailV2> { Title = "Address", Value = d => d.EventAddressV2Name },
        new DataTableColumn<LoopDetailV2> { Title = "Active", Value = d => d.ActiveQuarantined },
        new DataTableColumn<LoopDetailV2> { Title = "Archived", Value = d => d.ArchivedQuarantined },
        new DataTableColumn<LoopDetailV2> { Title = "In Window", Value = d => d.InWindow },
        new DataTableColumn<LoopDetailV2> { Title = "Most Recent", Value = d => d.MostRecentDetection?.ToString("u") ?? "—" },
    };

    protected override async Task LoadAsync(TrafficPeriodV2 period, DateTimeOffset windowStart)
    {
        try
        {
            summary = await HealthViewService.RetrieveLoopSummaryAsync(period, windowStart);

            details = (summary.ByAddress ?? Enumerable.Empty<LoopDetailV2>()).ToList();
            labels = details.Select(d => d.EventAddressV2Name).ToList();
            datasets = new List<ChartDataset>
            {
                new ChartDataset
                {
                    Label = "In Window",
                    Data = details.Select(d => (double)d.InWindow).ToList(),
                    Colors = new List<string> { "#e55353" }
                }
            };

            errorMessage = null;
        }
        catch
        {
            errorMessage = "Unable to load loop detection.";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
