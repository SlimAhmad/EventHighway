@namespace EventHighway.Portal.Web.Components.Dashboard
@using System.Linq
@using EventHighway.Core.Models.Coordinations.HealthChecks.V2
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Services.Views.HealthDashboards
@inject IHealthViewService HealthViewService

<Card CssClass="mb-4">
    <HeaderContent>
        <div class="d-flex justify-content-between align-items-center w-100">
            <span class="fw-semibold">Duplicate Detection</span>
            <span class="text-body-secondary small">@(summary?.WindowLabel)</span>
        </div>
    </HeaderContent>
    <ChildContent>
        @if (isLoading)
        {
            <Spinner />
        }
        else if (errorMessage is not null)
        {
            <div class="alert alert-danger mb-0" role="alert">@errorMessage</div>
        }
        else if (summary is not null)
        {
            <div class="row">
                <div class="col-md-4">
                    <div class="row mb-3">
                        <div class="col"><StatTile Variant="StatTileVariant.Amber" Value="@summary.TotalDuplicatesDetected.ToString()" Label="Duplicates" /></div>
                        <div class="col"><StatTile Variant="StatTileVariant.Na" Value="@summary.OverallDuplicateRate.ToString("0.00")" Label="Rate %" /></div>
                    </div>
                    <Chart ChartType="doughnut" Labels="doughnutLabels" Datasets="doughnutDatasets" Height="200" />
                </div>
                <div class="col-md-8">
                    <DataTable TItem="DuplicateDetailV2" Items="details" Columns="columns" Searchable="false" />
                </div>
            </div>
        }
    </ChildContent>
</Card>

@code {
    [Parameter] public TrafficPeriodV2 Period { get; set; } = TrafficPeriodV2.Day;
    [Parameter] public DateTimeOffset WindowStart { get; set; } = DateTimeOffset.MinValue;
    [Parameter] public int RefreshToken { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private DuplicateDetectionSummaryV2? summary;
    private List<DuplicateDetailV2> details = new();
    private List<string> doughnutLabels = new() { "Unique", "Duplicates" };
    private List<ChartDataset> doughnutDatasets = new();
    private List<DataTableColumn<DuplicateDetailV2>> columns = new();
    private (TrafficPeriodV2, DateTimeOffset, int)? loadedKey;

    protected override void OnInitialized()
    {
        columns = new List<DataTableColumn<DuplicateDetailV2>>
        {
            new DataTableColumn<DuplicateDetailV2> { Title = "Address", Value = d => d.AddressName },
            new DataTableColumn<DuplicateDetailV2> { Title = "Participant", Value = d => d.ParticipantName ?? "Unknown" },
            new DataTableColumn<DuplicateDetailV2> { Title = "Total", Value = d => d.TotalEvents },
            new DataTableColumn<DuplicateDetailV2> { Title = "Duplicates", Value = d => d.Duplicates },
            new DataTableColumn<DuplicateDetailV2> { Title = "Rate %", Value = d => d.DuplicateRate.ToString("0.00") },
            new DataTableColumn<DuplicateDetailV2> { Title = "Last Seen", Value = d => d.LastDuplicateSeen?.ToString("u") ?? "—" },
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        var key = (Period, WindowStart, RefreshToken);
        if (loadedKey == key) return;
        loadedKey = key;

        try
        {
            summary = await HealthViewService.RetrieveDuplicateSummaryAsync(
                Period, WindowStart);

            details = (summary.ByAddress ?? Enumerable.Empty<DuplicateDetailV2>()).ToList();
            doughnutDatasets = new List<ChartDataset>
            {
                new ChartDataset
                {
                    Label = "Events",
                    Data = new List<double> { summary.TotalUniqueEvents, summary.TotalDuplicatesDetected },
                    Colors = new List<string> { "#2eb85c", "#e55353" }
                }
            };
        }
        catch
        {
            errorMessage = "Unable to load duplicate detection.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
