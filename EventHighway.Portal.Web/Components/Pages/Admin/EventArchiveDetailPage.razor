@page "/admin/event-archives/{EventArchiveId:guid}"
@attribute [Authorize(Roles = "Administrators")]
@using System.Collections.Generic
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.EventArchives
@using EventHighway.Portal.Web.Models.Views.ListenerEventArchives
@using EventHighway.Portal.Web.Services.Views.EventArchives
@using EventHighway.Portal.Web.Services.Views.ListenerEventArchives
@inject IEventArchivesViewService EventArchivesViewService
@inject IListenerEventArchivesViewService ListenerEventArchivesViewService

<PageTitle>Archived Event</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Archived Event</h2>
    <a class="btn btn-outline-secondary btn-sm" href="admin/event-archives">Back to list</a>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else if (eventArchive is not null)
{
    <Card>
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <span class="fw-semibold">Archived Event</span>
                <span class="badge @StatusCssClass">@eventArchive.Status</span>
            </div>
        </HeaderContent>
        <ChildContent>
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@eventArchive.Id</dd>

                <dt class="col-sm-3">Event Name</dt>
                <dd class="col-sm-9">@DisplayOrDash(eventArchive.EventName)</dd>

                <dt class="col-sm-3">Content</dt>
                <dd class="col-sm-9"><pre class="mb-0 text-wrap">@DisplayOrDash(eventArchive.Content)</pre></dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@eventArchive.Type</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@eventArchive.Status</dd>

                <dt class="col-sm-3">Retries Left</dt>
                <dd class="col-sm-9">@eventArchive.RemainingRetryAttempts</dd>

                <dt class="col-sm-3">Event Address Id</dt>
                <dd class="col-sm-9">@eventArchive.EventAddressId</dd>

                <dt class="col-sm-3">Participant Id</dt>
                <dd class="col-sm-9">@(eventArchive.ParticipantId?.ToString() ?? "—")</dd>

                <dt class="col-sm-3">Scheduled</dt>
                <dd class="col-sm-9">@(eventArchive.ScheduledDate?.ToString("u") ?? "—")</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@eventArchive.CreatedDate.ToString("u")</dd>

                <dt class="col-sm-3">Archived</dt>
                <dd class="col-sm-9">@eventArchive.ArchivedDate.ToString("u")</dd>
            </dl>
        </ChildContent>
    </Card>

    <Card CssClass="mt-4">
        <HeaderContent>
            <span class="fw-semibold">Dispatched listener events</span>
        </HeaderContent>
        <ChildContent>
            @if (listenerEventArchives.Count == 0)
            {
                <p class="text-body-secondary mb-0">No events dispatched.</p>
            }
            else
            {
                <DataTable TItem="ListenerEventArchiveView" Items="listenerEventArchives"
                           Columns="listenerColumns" Searchable="true" />
            }
        </ChildContent>
    </Card>
}
else
{
    <div class="alert alert-warning" role="alert">Archived event not found.</div>
}

@code {
    [Parameter]
    public Guid EventArchiveId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private EventArchiveView? eventArchive;
    private List<ListenerEventArchiveView> listenerEventArchives = new();
    private List<DataTableColumn<ListenerEventArchiveView>> listenerColumns = new();

    private string StatusCssClass =>
        eventArchive?.Status switch
        {
            "Active" => "text-bg-success",
            "Quarantined" => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    protected override async Task OnInitializedAsync()
    {
        listenerColumns = new List<DataTableColumn<ListenerEventArchiveView>>
        {
            new DataTableColumn<ListenerEventArchiveView> { Title = "Id", Value = a => a.Id },
            new DataTableColumn<ListenerEventArchiveView> { Title = "Status", Value = a => a.Status },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Response Code", Value = a => a.ResponseCode
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Response Message", Value = a => a.ResponseMessage
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Listener", Value = a => a.EventListenerId
            },
            new DataTableColumn<ListenerEventArchiveView>
            {
                Title = "Archived", Value = a => a.ArchivedDate.ToString("u")
            },
        };

        try
        {
            eventArchive =
                await EventArchivesViewService.RetrieveEventArchiveByIdAsync(EventArchiveId);

            if (eventArchive is not null)
            {
                listenerEventArchives =
                    await ListenerEventArchivesViewService
                        .RetrieveListenerEventArchivesByEventArchiveIdAsync(EventArchiveId);
            }
        }
        catch
        {
            errorMessage = "Unable to load this archived event. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string DisplayOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;
}
