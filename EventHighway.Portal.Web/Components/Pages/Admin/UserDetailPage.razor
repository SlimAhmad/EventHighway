@page "/admin/users/{UserId:guid}"
@attribute [Authorize(Roles = "Administrators")]
@using System.Collections.Generic
@using System.Linq
@using System.Text
@using Microsoft.AspNetCore.WebUtilities
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.Users
@using EventHighway.Portal.Web.Services.Views.Users
@inject IUsersViewService UsersViewService
@inject NavigationManager Navigation

<PageTitle>User</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">User</h2>
    <Button Color="secondary" OnClick="GoBack">Back to Users</Button>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else if (user is not null)
{
    @if (actionError is not null)
    {
        <div class="alert alert-danger" role="alert">@actionError</div>
    }
    @if (actionMessage is not null)
    {
        <div class="alert alert-success" role="alert">@actionMessage</div>
    }
    @if (generatedLink is not null)
    {
        <div class="alert alert-info" role="alert">
            <div class="fw-semibold mb-1">@generatedLinkLabel</div>
            <textarea class="form-control" rows="2" readonly>@generatedLink</textarea>
        </div>
    }

    <Card CssClass="mb-4">
        <HeaderContent>User Details</HeaderContent>
        <ChildContent>
            <div class="mb-3 d-flex flex-wrap gap-2">
                <span class="badge @(user.EmailConfirmed ? "text-bg-success" : "text-bg-secondary")">
                    Email @(user.EmailConfirmed ? "confirmed" : "unconfirmed")
                </span>
                <span class="badge @(user.IsLockedOut ? "text-bg-danger" : "text-bg-success")">
                    @(user.IsLockedOut ? "Locked out" : "Not locked")
                </span>
                <span class="badge @(user.TwoFactorEnabled ? "text-bg-info" : "text-bg-secondary")">
                    2FA @(user.TwoFactorEnabled ? "on" : "off")
                </span>
                <span class="badge @(user.IsDisabled ? "text-bg-danger" : "text-bg-success")">
                    @(user.IsDisabled ? "Disabled" : "Active")
                </span>
                <span class="badge text-bg-light text-dark border">
                    Failed logins: @user.AccessFailedCount
                </span>
            </div>

            <FormText Label="Username" @bind-Value="editUser.UserName" />
            <FormText Label="Email" @bind-Value="editUser.Email" />
            <FormText Label="Phone Number" @bind-Value="editUser.PhoneNumber" />
            <Button Color="primary" OnClick="SaveProfileAsync">Save Profile</Button>
        </ChildContent>
    </Card>

    <Card CssClass="mb-4">
        <HeaderContent>Roles</HeaderContent>
        <ChildContent>
            @if (user.Roles.Any())
            {
                <ul class="list-group mb-3">
                    @foreach (string role in user.Roles)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @role
                            <Button Color="danger"
                                    CssClass="btn-sm"
                                    OnClick="@(() => RemoveRoleAsync(role))">
                                Remove
                            </Button>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-body-secondary">This user has no roles assigned.</p>
            }

            <div class="d-flex gap-2 align-items-center">
                <FormSelect Label="Add Role"
                            Options="availableRoleOptions"
                            @bind-Value="selectedRoleToAdd" />
                <Button Color="primary" OnClick="AddRoleAsync">Add</Button>
            </div>
        </ChildContent>
    </Card>

    <Card CssClass="mb-4">
        <HeaderContent>Account Actions</HeaderContent>
        <ChildContent>
            <div class="d-flex flex-wrap gap-2">
                @if (!user.EmailConfirmed)
                {
                    <Button Color="success" CssClass="btn-sm" OnClick="ConfirmEmailAsync">
                        Confirm Email
                    </Button>
                }
                <Button Color="secondary" CssClass="btn-sm" OnClick="GenerateConfirmationLinkAsync">
                    Email Confirmation Link
                </Button>
                <Button Color="secondary" CssClass="btn-sm" OnClick="GenerateResetLinkAsync">
                    Password Reset Link
                </Button>
                @if (user.IsLockedOut)
                {
                    <Button Color="warning" CssClass="btn-sm" OnClick="UnlockAsync">Unlock</Button>
                }
                else
                {
                    <Button Color="warning" CssClass="btn-sm" OnClick="LockAsync">Lock</Button>
                }
                <Button Color="secondary" CssClass="btn-sm" OnClick="ResetFailedCountAsync">
                    Reset Failed Count
                </Button>
                @if (user.TwoFactorEnabled)
                {
                    <Button Color="secondary" CssClass="btn-sm" OnClick="@(() => SetTwoFactorAsync(false))">
                        Disable 2FA
                    </Button>
                }
                else
                {
                    <Button Color="secondary" CssClass="btn-sm" OnClick="@(() => SetTwoFactorAsync(true))">
                        Enable 2FA
                    </Button>
                }
                @if (user.IsDisabled)
                {
                    <Button Color="success" CssClass="btn-sm" OnClick="EnableUserAsync">
                        Enable User
                    </Button>
                }
                else
                {
                    <Button Color="danger" CssClass="btn-sm" OnClick="DisableUserAsync">
                        Disable User
                    </Button>
                }
                <Button Color="danger" CssClass="btn-sm" OnClick="OpenDeleteModal">
                    Delete User
                </Button>
            </div>
        </ChildContent>
    </Card>

    <Modal Title="Delete User" Visible="showDeleteModal" OnClose="CloseDeleteModal">
        <ChildContent>
            <p>
                Permanently delete <strong>@user.UserName</strong>? This cannot be undone.
                Consider <em>Disable User</em> (soft-delete) instead.
            </p>
        </ChildContent>
        <FooterContent>
            <Button Color="secondary" OnClick="CloseDeleteModal">Cancel</Button>
            <Button Color="danger" OnClick="DeleteUserAsync">Delete</Button>
        </FooterContent>
    </Modal>
}

@code {
    [Parameter]
    public Guid UserId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private string? actionError;
    private string? actionMessage;
    private string? generatedLink;
    private string? generatedLinkLabel;
    private UserView? user;
    private UserView editUser = new();
    private List<string> allRoleNames = new();
    private List<SelectOption> availableRoleOptions = new();
    private string? selectedRoleToAdd = string.Empty;
    private bool showDeleteModal;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            allRoleNames = await UsersViewService.RetrieveAllRoleNamesAsync();
            await ReloadUserAsync();
        }
        catch
        {
            errorMessage = "Unable to load the user. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadUserAsync()
    {
        user = await UsersViewService.RetrieveUserByIdAsync(UserId);

        editUser = new UserView
        {
            Id = user.Id,
            UserName = user.UserName,
            Email = user.Email,
            PhoneNumber = user.PhoneNumber
        };

        availableRoleOptions = allRoleNames
            .Where(role => !user.Roles.Contains(role))
            .Select(role => new SelectOption { Text = role, Value = role })
            .ToList();

        selectedRoleToAdd = availableRoleOptions.FirstOrDefault()?.Value ?? string.Empty;
    }

    private void ClearNotices()
    {
        actionError = null;
        actionMessage = null;
        generatedLink = null;
        generatedLinkLabel = null;
    }

    private async Task RunAsync(Func<Task> action, string successMessage, string failureMessage)
    {
        ClearNotices();

        try
        {
            await action();
            await ReloadUserAsync();
            actionMessage = successMessage;
        }
        catch
        {
            actionError = failureMessage;
        }
    }

    private Task SaveProfileAsync() =>
        RunAsync(
            () => UsersViewService.ModifyUserAsync(editUser).AsTask(),
            "Profile updated.",
            "Unable to update the profile. Please try again.");

    private Task AddRoleAsync()
    {
        if (string.IsNullOrWhiteSpace(selectedRoleToAdd))
        {
            return Task.CompletedTask;
        }

        string role = selectedRoleToAdd;

        return RunAsync(
            () => UsersViewService.AddUserToRoleAsync(UserId, role).AsTask(),
            "Role added.",
            "Unable to add the role. Please try again.");
    }

    private Task RemoveRoleAsync(string role) =>
        RunAsync(
            () => UsersViewService.RemoveUserFromRoleAsync(UserId, role).AsTask(),
            "Role removed.",
            "Unable to remove the role. The last administrator cannot be removed.");

    private Task ConfirmEmailAsync() =>
        RunAsync(
            () => UsersViewService.ConfirmUserEmailAsync(UserId).AsTask(),
            "Email confirmed.",
            "Unable to confirm the email. Please try again.");

    private Task LockAsync() =>
        RunAsync(
            () => UsersViewService.LockUserAsync(UserId).AsTask(),
            "User locked out.",
            "Unable to lock the user. The last administrator cannot be locked.");

    private Task UnlockAsync() =>
        RunAsync(
            () => UsersViewService.UnlockUserAsync(UserId).AsTask(),
            "User unlocked.",
            "Unable to unlock the user. Please try again.");

    private Task ResetFailedCountAsync() =>
        RunAsync(
            () => UsersViewService.ResetAccessFailedCountAsync(UserId).AsTask(),
            "Failed login count reset.",
            "Unable to reset the failed login count. Please try again.");

    private Task SetTwoFactorAsync(bool enabled) =>
        RunAsync(
            () => UsersViewService.SetTwoFactorEnabledAsync(UserId, enabled).AsTask(),
            enabled ? "Two-factor enabled." : "Two-factor disabled.",
            "Unable to change two-factor. Please try again.");

    private Task DisableUserAsync() =>
        RunAsync(
            () => UsersViewService.DisableUserAsync(UserId).AsTask(),
            "User disabled.",
            "Unable to disable the user. The last administrator cannot be disabled.");

    private Task EnableUserAsync() =>
        RunAsync(
            () => UsersViewService.EnableUserAsync(UserId).AsTask(),
            "User enabled.",
            "Unable to enable the user. Please try again.");

    private async Task GenerateConfirmationLinkAsync()
    {
        ClearNotices();

        try
        {
            string token = await UsersViewService.GenerateEmailConfirmationTokenAsync(UserId);
            string code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));

            generatedLink = Navigation.ToAbsoluteUri(
                $"Account/ConfirmEmail?userId={UserId}&code={code}").ToString();

            generatedLinkLabel = "Email confirmation link (share with the user):";
        }
        catch
        {
            actionError = "Unable to generate the confirmation link. Please try again.";
        }
    }

    private async Task GenerateResetLinkAsync()
    {
        ClearNotices();

        try
        {
            string token = await UsersViewService.GeneratePasswordResetTokenAsync(UserId);
            string code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(token));

            generatedLink = Navigation.ToAbsoluteUri(
                $"Account/ResetPassword?code={code}").ToString();

            generatedLinkLabel = "Password reset link (share with the user):";
        }
        catch
        {
            actionError = "Unable to generate the reset link. Please try again.";
        }
    }

    private void OpenDeleteModal()
    {
        ClearNotices();
        showDeleteModal = true;
    }

    private void CloseDeleteModal() =>
        showDeleteModal = false;

    private async Task DeleteUserAsync()
    {
        showDeleteModal = false;

        try
        {
            await UsersViewService.RemoveUserByIdAsync(UserId);
            Navigation.NavigateTo("/admin/users");
        }
        catch
        {
            actionError = "Unable to delete the user. The last administrator cannot be removed.";
        }
    }

    private void GoBack() =>
        Navigation.NavigateTo("/admin/users");
}
