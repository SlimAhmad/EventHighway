@page "/admin/events"
@attribute [Authorize(Roles = "Administrators")]
@using System.Collections.Generic
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.Events
@using EventHighway.Portal.Web.Services.Views.EventArchives
@using EventHighway.Portal.Web.Services.Views.Events
@inject IEventArchivesViewService EventArchivesViewService
@inject IEventsViewService EventsViewService
@inject NavigationManager Navigation

<PageTitle>Events</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Events</h2>
</div>

<p class="text-body-secondary">
    Events queued for delivery, most recent first. Each row is one event submitted to the highway.
</p>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else
{
    <Card CssClass="mb-4">
        <HeaderContent>
            <span class="fw-semibold">Archive processed events</span>
        </HeaderContent>
        <ChildContent>
            @if (archiveMessage is not null)
            {
                <div class="alert @archiveAlertClass" role="alert">@archiveMessage</div>
            }
            <p class="text-body-secondary">
                <strong>@archivableCount</strong>
                @(archivableCount == 1 ? " event qualifies" : " events qualify")
                for archiving and can be moved out of the live tables and into the archive.
            </p>
            <Button Color="primary" OnClick="ArchiveAsync" Disabled="@isWorking">
                Archive now
            </Button>
        </ChildContent>
    </Card>

    <Card>
        <DataTable TItem="EventView" Items="events" Columns="columns" Searchable="true">
            <RowActions Context="eventItem">
                <Button Color="primary" CssClass="btn-sm"
                        OnClick="@(() => ViewEvent(eventItem.Id))">
                    VIEW
                </Button>
            </RowActions>
        </DataTable>
    </Card>
}

@code {
    private bool isLoading = true;
    private bool isWorking;
    private string? errorMessage;
    private int archivableCount;
    private List<EventView> events = new();
    private List<DataTableColumn<EventView>> columns = new();

    private string? archiveMessage;
    private string archiveAlertClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        columns = new List<DataTableColumn<EventView>>
        {
            new DataTableColumn<EventView> { Title = "Id", Value = e => e.Id },
            new DataTableColumn<EventView> { Title = "Event Name", Value = e => e.EventName },
            new DataTableColumn<EventView> { Title = "Content", Value = e => e.Content },
            new DataTableColumn<EventView> { Title = "Type", Value = e => e.Type },
            new DataTableColumn<EventView> { Title = "Status", Value = e => e.Status },
            new DataTableColumn<EventView>
            {
                Title = "Retries Left", Value = e => e.RemainingRetryAttempts
            },
            new DataTableColumn<EventView>
            {
                Title = "Created", Value = e => e.CreatedDate.ToString("u")
            },
        };

        await LoadAsync();
        isLoading = false;
    }

    private async Task LoadAsync()
    {
        try
        {
            events = await EventsViewService.RetrieveAllEventsAsync();
            archivableCount = await EventsViewService.RetrieveArchivableEventCountAsync();
            errorMessage = null;
        }
        catch
        {
            errorMessage = "Unable to load events. Please try again.";
        }
    }

    private async Task ArchiveAsync()
    {
        isWorking = true;
        archiveMessage = null;

        try
        {
            await EventArchivesViewService.ArchiveProcessedEventsAsync();
            archiveAlertClass = "alert-success";
            archiveMessage = "Processed events archived.";
            await LoadAsync();
        }
        catch
        {
            archiveAlertClass = "alert-danger";
            archiveMessage = "Unable to archive events. Please try again.";
        }
        finally
        {
            isWorking = false;
        }
    }

    private void ViewEvent(Guid eventId) =>
        Navigation.NavigateTo($"/admin/events/{eventId}");
}
