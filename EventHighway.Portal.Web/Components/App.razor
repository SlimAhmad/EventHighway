<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="vendors/@@coreui/icons/css/free.min.css" />
    <link rel="stylesheet" href="css/style.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["EventHighway.Portal.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script src="js/eventHighwayTheme.js"></script>
    <HeadOutlet @rendermode="@PageRenderMode" />
</head>

<body>
    <Routes @rendermode="@PageRenderMode" />
    <ReconnectModal />
    <script src="vendors/@@coreui/coreui/js/coreui.bundle.min.js"></script>
    <script src="vendors/chart.js/js/chart.umd.js"></script>
    <script src="js/eventHighwayCharts.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="@Assets["Components/Account/Shared/PasskeySubmit.razor.js"]" type="module"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    // The Identity Account pages must render with static SSR so cookie sign-in/out works against
    // HttpContext. Every other page (dashboard, admin) runs on the InteractiveServer circuit so
    // buttons, modals and navigation are live. The decision is keyed off the request path because
    // HttpContext is always present during the initial server render — a "HttpContext is null"
    // check would render every page statically on first load and never start the circuit.
    private IComponentRenderMode? PageRenderMode =>
        HttpContext.Request.Path.StartsWithSegments("/Account")
            ? null
            : InteractiveServer;
}
