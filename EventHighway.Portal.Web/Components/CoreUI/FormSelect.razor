@namespace EventHighway.Portal.Web.Components.CoreUI

<div class="d-inline-flex align-items-center gap-2">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="form-label mb-0 small text-nowrap">@Label</label>
    }
    <select class="form-select form-select-sm" value="@Value" @onchange="OnChangeAsync">
        @foreach (SelectOption option in Options)
        {
            <option value="@option.Value" selected="@(option.Value == Value)">@option.Text</option>
        }
    </select>
</div>
