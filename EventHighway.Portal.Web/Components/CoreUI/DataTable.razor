@namespace EventHighway.Portal.Web.Components.CoreUI
@typeparam TItem

<div class="datatable">
    @if (Searchable || ExtraFilters is not null)
    {
        <div class="d-flex gap-2 mb-3">
            @if (Searchable)
            {
                <input type="search"
                       class="form-control datatable-search"
                       placeholder="Search..."
                       value="@SearchTerm"
                       @oninput="OnSearchChanged" />
            }
            @ExtraFilters
        </div>
    }

    <table class="table table-hover align-middle">
        <thead>
            <tr>
                @foreach (DataTableColumn<TItem> column in Columns)
                {
                    @if (column.Sortable)
                    {
                        <th role="button" class="user-select-none" @onclick="() => ToggleSort(column)">
                            @column.Title
                            @if (SortColumn == column)
                            {
                                <i class="ms-1 @(SortAscending ? "cil-arrow-top" : "cil-arrow-bottom")"></i>
                            }
                        </th>
                    }
                    else
                    {
                        <th>@column.Title</th>
                    }
                }
                @if (RowActions is not null)
                {
                    <th class="text-end"></th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (TItem item in PagedItems)
            {
                <tr class="@RowClass?.Invoke(item)">
                    @foreach (DataTableColumn<TItem> column in Columns)
                    {
                        <td>
                            @if (column.CellTemplate is not null)
                            {
                                @column.CellTemplate(item)
                            }
                            else
                            {
                                @column.Value(item)
                            }
                        </td>
                    }
                    @if (RowActions is not null)
                    {
                        <td class="text-end">@RowActions(item)</td>
                    }
                </tr>
            }
        </tbody>
    </table>

    @if (PageCount > 1)
    {
        <nav class="d-flex justify-content-between align-items-center datatable-pager">
            <button type="button"
                    class="btn btn-sm btn-outline-secondary datatable-prev"
                    disabled="@(CurrentPage <= 1)"
                    @onclick="PreviousPage">
                Previous
            </button>

            <span class="small">Page @CurrentPage of @PageCount</span>

            <button type="button"
                    class="btn btn-sm btn-outline-secondary datatable-next"
                    disabled="@(CurrentPage >= PageCount)"
                    @onclick="NextPage">
                Next
            </button>
        </nav>
    }
</div>
