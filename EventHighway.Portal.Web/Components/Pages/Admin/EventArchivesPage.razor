@page "/admin/event-archives"
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Services.Views.EventArchives
@inject IEventArchivesViewService EventArchivesViewService

<PageTitle>Event Archives</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Event Archives</h2>
</div>

<p class="text-body-secondary">
    Archive maintenance operations. Live archive counts are shown on the Health Dashboard.
</p>

@if (message is not null)
{
    <div class="alert @alertClass" role="alert">@message</div>
}

<Card CssClass="mb-4">
    <HeaderContent>
        <span class="fw-semibold">Archive processed events</span>
    </HeaderContent>
    <ChildContent>
        <p class="text-body-secondary">
            Move processed events out of the live tables and into the archive.
        </p>
        <Button Color="primary" OnClick="ArchiveNowAsync" Disabled="@isWorking">
            Archive now
        </Button>
    </ChildContent>
</Card>

<Card>
    <HeaderContent>
        <span class="fw-semibold">Purge old archives</span>
    </HeaderContent>
    <ChildContent>
        <div class="d-flex flex-wrap align-items-end gap-3">
            <div style="min-width: 14rem;">
                <FormDate Label="Purge archives older than" @bind-Value="purgeOlderThan" />
            </div>
            <div class="mb-3">
                <Button Color="danger" OnClick="RequestPurge"
                        Disabled="@(isWorking || purgeOlderThan is null)">
                    Purge
                </Button>
            </div>
        </div>
    </ChildContent>
</Card>

<ConfirmDialog Visible="confirmVisible"
               Title="Confirm purge"
               Message="@confirmMessage"
               ConfirmText="OK"
               CancelText="Cancel"
               OnConfirm="PurgeAsync"
               OnCancel="@(() => confirmVisible = false)" />

@code {
    private bool isWorking;
    private string? message;
    private string alertClass = "alert-info";

    private DateTimeOffset? purgeOlderThan;
    private bool confirmVisible;
    private string? confirmMessage;

    private async Task ArchiveNowAsync()
    {
        isWorking = true;
        message = null;

        try
        {
            await EventArchivesViewService.ArchiveProcessedEventsAsync();
            alertClass = "alert-success";
            message = "Processed events archived.";
        }
        catch
        {
            alertClass = "alert-danger";
            message = "Unable to archive events. Please try again.";
        }
        finally
        {
            isWorking = false;
        }
    }

    private void RequestPurge()
    {
        if (purgeOlderThan is null)
        {
            return;
        }

        confirmMessage =
            $"Purge all archives created before {purgeOlderThan:yyyy-MM-dd}? This cannot be undone.";

        confirmVisible = true;
    }

    private async Task PurgeAsync()
    {
        confirmVisible = false;
        isWorking = true;
        message = null;

        try
        {
            await EventArchivesViewService.PurgeArchivesOlderThanAsync(purgeOlderThan!.Value);
            alertClass = "alert-success";
            message = "Old archives purged.";
        }
        catch
        {
            alertClass = "alert-danger";
            message = "Unable to purge archives. Please try again.";
        }
        finally
        {
            isWorking = false;
        }
    }
}
