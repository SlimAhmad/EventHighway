@page "/admin/participants"
@attribute [Authorize(Roles = "Administrators")]
@using System.Collections.Generic
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.EventParticipants
@using EventHighway.Portal.Web.Services.Views.EventParticipants
@inject IEventParticipantsViewService ParticipantsViewService
@inject NavigationManager Navigation

<PageTitle>Event Participants</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Event Participants</h2>
    <Button Color="primary" OnClick="OpenAddModal">Add Participant</Button>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else
{
    <Card>
        <DataTable TItem="EventParticipantView" Items="participants" Columns="columns">
            <RowActions Context="participant">
                <Button Color="primary"
                        CssClass="btn-sm"
                        OnClick="@(() => ViewParticipant(participant.Id))">
                    VIEW
                </Button>
            </RowActions>
        </DataTable>
    </Card>
}

<Modal Title="Add Participant" Visible="showAddModal" OnClose="CloseAddModal">
    <ChildContent>
        @if (addErrorMessage is not null)
        {
            <div class="alert alert-danger" role="alert">@addErrorMessage</div>
        }
        <FormText Label="Name" @bind-Value="newParticipant.Name" />
        <FormText Label="Description" @bind-Value="newParticipant.Description" />
        <FormText Label="Contact Email" @bind-Value="newParticipant.ContactEmail" />
        <FormText Label="Contact Phone" @bind-Value="newParticipant.ContactPhone" />
        <FormSwitch Label="Active" @bind-Value="newParticipant.IsActive" />
    </ChildContent>
    <FooterContent>
        <Button Color="secondary" OnClick="CloseAddModal">Cancel</Button>
        <Button Color="primary" OnClick="SubmitAddAsync">Save</Button>
    </FooterContent>
</Modal>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<EventParticipantView> participants = new();
    private List<DataTableColumn<EventParticipantView>> columns = new();

    private bool showAddModal;
    private string? addErrorMessage;
    private EventParticipantView newParticipant = new() { IsActive = true };

    protected override async Task OnInitializedAsync()
    {
        columns = new List<DataTableColumn<EventParticipantView>>
        {
            new DataTableColumn<EventParticipantView>
            {
                Title = "Id", Value = participant => participant.Id
            },
            new DataTableColumn<EventParticipantView>
            {
                Title = "Name", Value = participant => participant.Name
            },
            new DataTableColumn<EventParticipantView>
            {
                Title = "Description", Value = participant => participant.Description
            },
            new DataTableColumn<EventParticipantView>
            {
                Title = "Contact Email", Value = participant => participant.ContactEmail
            },
            new DataTableColumn<EventParticipantView>
            {
                Title = "Active", Value = participant => participant.IsActive ? "Yes" : "No"
            },
        };

        try
        {
            participants = await ParticipantsViewService.RetrieveAllParticipantsAsync();
        }
        catch
        {
            errorMessage = "Unable to load participants. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ViewParticipant(Guid participantId) =>
        Navigation.NavigateTo($"/admin/participants/{participantId}");

    private void OpenAddModal()
    {
        newParticipant = new EventParticipantView { IsActive = true };
        addErrorMessage = null;
        showAddModal = true;
    }

    private void CloseAddModal() =>
        showAddModal = false;

    private async Task SubmitAddAsync()
    {
        try
        {
            await ParticipantsViewService.AddParticipantAsync(newParticipant);
            showAddModal = false;
            participants = await ParticipantsViewService.RetrieveAllParticipantsAsync();
        }
        catch
        {
            addErrorMessage = "Unable to add the participant. Please check the details and try again.";
        }
    }
}
