@namespace EventHighway.Portal.Web.Components.Dashboard
@using System.Linq
@using EventHighway.Core.Models.Coordinations.HealthChecks.V2
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Services.Views.HealthDashboards
@inject IHealthViewService HealthViewService

<Card CssClass="mb-4">
    <HeaderContent>
        <div class="d-flex justify-content-between align-items-center w-100">
            <span class="fw-semibold">Traffic</span>
            <span class="text-body-secondary small">@(snapshot?.WindowLabel)</span>
        </div>
    </HeaderContent>
    <ChildContent>
        @if (isLoading)
        {
            <Spinner />
        }
        else if (errorMessage is not null)
        {
            <div class="alert alert-danger mb-0" role="alert">@errorMessage</div>
        }
        else if (snapshot is not null)
        {
            <div class="row text-center mb-3">
                <div class="col"><div class="fs-5 fw-semibold">@snapshot.TotalEvents</div><div class="small text-body-secondary">Events</div></div>
                <div class="col"><div class="fs-5 fw-semibold text-success">@snapshot.TotalSuccess</div><div class="small text-body-secondary">Success</div></div>
                <div class="col"><div class="fs-5 fw-semibold text-danger">@snapshot.TotalErrors</div><div class="small text-body-secondary">Errors</div></div>
                <div class="col"><div class="fs-5 fw-semibold text-warning">@snapshot.TotalPending</div><div class="small text-body-secondary">Pending</div></div>
                <div class="col"><div class="fs-5 fw-semibold text-info">@snapshot.TotalReplays</div><div class="small text-body-secondary">Replays</div></div>
            </div>
            <Chart ChartType="line" Labels="labels" Datasets="datasets" Height="260" />
        }
    </ChildContent>
</Card>

@code {
    [Parameter] public TrafficPeriodV2 Period { get; set; } = TrafficPeriodV2.Day;
    [Parameter] public DateTimeOffset WindowStart { get; set; } = DateTimeOffset.MinValue;
    [Parameter] public int RefreshToken { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private TrafficSnapshotV2? snapshot;
    private List<string> labels = new();
    private List<ChartDataset> datasets = new();
    private (TrafficPeriodV2, DateTimeOffset, int)? loadedKey;

    protected override async Task OnParametersSetAsync()
    {
        var key = (Period, WindowStart, RefreshToken);
        if (loadedKey == key) return;
        loadedKey = key;

        try
        {
            snapshot = await HealthViewService.RetrieveTrafficSnapshotAsync(
                Period, WindowStart);

            var buckets = (snapshot.Buckets ?? Enumerable.Empty<TrafficBucketV2>()).ToList();
            labels = buckets.Select(bucket => bucket.Label).ToList();

            datasets = new List<ChartDataset>
            {
                new ChartDataset
                {
                    Label = "Events",
                    Data = buckets.Select(bucket => (double)bucket.Events).ToList(),
                    Colors = new List<string> { "#321fdb" }
                },
                new ChartDataset
                {
                    Label = "Listener Events",
                    Data = buckets.Select(bucket => (double)bucket.ListenerEvents).ToList(),
                    Colors = new List<string> { "#2eb85c" },
                    Dashed = true,
                    Fill = false
                },
            };
        }
        catch
        {
            errorMessage = "Unable to load traffic.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
