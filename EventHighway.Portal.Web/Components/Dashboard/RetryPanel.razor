@namespace EventHighway.Portal.Web.Components.Dashboard
@using System.Linq
@using EventHighway.Core.Models.Coordinations.HealthChecks.V2
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Services.Views.HealthDashboards
@inject IHealthViewService HealthViewService

<Card CssClass="mb-4">
    <HeaderContent><span class="fw-semibold">Retry Health</span></HeaderContent>
    <ChildContent>
        @if (isLoading)
        {
            <Spinner />
        }
        else if (errorMessage is not null)
        {
            <div class="alert alert-danger mb-0" role="alert">@errorMessage</div>
        }
        else if (summary is not null)
        {
            <div class="row mb-3">
                <div class="col"><StatTile Variant="StatTileVariant.Red" Value="@summary.DeadEvents.ToString()" Label="Dead (0)" /></div>
                <div class="col"><StatTile Variant="StatTileVariant.Amber" Value="@summary.CriticalEvents.ToString()" Label="Critical (1-2)" /></div>
                <div class="col"><StatTile Variant="StatTileVariant.Green" Value="@summary.HealthyEvents.ToString()" Label="Healthy (3+)" /></div>
            </div>
            @if (labels.Count > 0)
            {
                <Chart ChartType="bar" Labels="labels" Datasets="datasets" Height="220" />
            }
            <DataTable TItem="RetryAddressDetailV2" Items="details" Columns="columns" Searchable="false" />
        }
    </ChildContent>
</Card>

@code {
    [Parameter] public int RefreshToken { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private RetryHealthSummaryV2? summary;
    private List<RetryAddressDetailV2> details = new();
    private List<string> labels = new();
    private List<ChartDataset> datasets = new();
    private List<DataTableColumn<RetryAddressDetailV2>> columns = new();
    private int? loadedToken;

    protected override void OnInitialized()
    {
        columns = new List<DataTableColumn<RetryAddressDetailV2>>
        {
            new DataTableColumn<RetryAddressDetailV2> { Title = "Address", Value = d => d.EventAddressV2Name },
            new DataTableColumn<RetryAddressDetailV2> { Title = "Dead", Value = d => d.DeadEvents },
            new DataTableColumn<RetryAddressDetailV2> { Title = "Critical", Value = d => d.CriticalEvents },
            new DataTableColumn<RetryAddressDetailV2> { Title = "Total", Value = d => d.TotalEvents },
        };
    }

    protected override async Task OnParametersSetAsync()
    {
        if (loadedToken == RefreshToken) return;
        loadedToken = RefreshToken;

        try
        {
            summary = await HealthViewService.RetrieveRetryHealthAsync();

            var distribution = (summary.Distribution ?? Enumerable.Empty<RetryBucketV2>()).ToList();
            labels = distribution.Select(b => b.RemainingRetries.ToString()).ToList();
            datasets = new List<ChartDataset>
            {
                new ChartDataset
                {
                    Label = "Events",
                    Data = distribution.Select(b => (double)b.Count).ToList(),
                    Colors = new List<string> { "#321fdb" }
                }
            };

            details = (summary.ByAddress ?? Enumerable.Empty<RetryAddressDetailV2>()).ToList();
        }
        catch
        {
            errorMessage = "Unable to load retry health.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
