@page "/admin/event-addresses/{AddressId:guid}"
@using System.Linq
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.EventAddresses
@using EventHighway.Portal.Web.Models.Views.EventListeners
@using EventHighway.Portal.Web.Services.Views.EventAddresses
@using EventHighway.Portal.Web.Services.Views.EventListeners
@inject IEventAddressesViewService AddressesViewService
@inject IEventListenersViewService ListenersViewService
@inject NavigationManager Navigation

<PageTitle>Event Address</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Event Address</h2>
    <a class="btn btn-outline-secondary btn-sm" href="admin/event-addresses">Back to list</a>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else if (address is not null)
{
    <Card>
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <span class="fw-semibold">@address.Name</span>
                <Button Color="danger" CssClass="btn-sm" OnClick="RequestDeleteAddress">
                    Delete
                </Button>
            </div>
        </HeaderContent>
        <ChildContent>
            @if (deleteError is not null)
            {
                <div class="alert alert-danger" role="alert">@deleteError</div>
            }
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@address.Id</dd>

                <dt class="col-sm-3">Description</dt>
                <dd class="col-sm-9">@address.Description</dd>
            </dl>
        </ChildContent>
    </Card>

    <Card Title="Event Listeners" CssClass="mt-4">
        @if (listenersError is not null)
        {
            <div class="alert alert-danger" role="alert">@listenersError</div>
        }
        else if (listeners.Count == 0)
        {
            <p class="text-body-secondary mb-0">No listeners registered for this address.</p>
        }
        else
        {
            <DataTable TItem="EventListenerView" Items="listeners" Columns="listenerColumns"
                       Searchable="false" />
        }
    </Card>
}
else
{
    <div class="alert alert-warning" role="alert">Address not found.</div>
}

<ConfirmDialog Visible="confirmVisible"
               Title="Confirm delete"
               Message="Deleting this address is permanent and cannot be undone."
               ConfirmText="OK"
               CancelText="Cancel"
               OnConfirm="DeleteAddressAsync"
               OnCancel="CancelDelete" />

@code {
    [Parameter]
    public Guid AddressId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private EventAddressView? address;

    private List<EventListenerView> listeners = new();
    private string? listenersError;
    private List<DataTableColumn<EventListenerView>> listenerColumns = new();

    private bool confirmVisible;
    private string? deleteError;

    protected override async Task OnInitializedAsync()
    {
        listenerColumns = new List<DataTableColumn<EventListenerView>>
        {
            new DataTableColumn<EventListenerView> { Title = "Name", Value = l => l.Name },
            new DataTableColumn<EventListenerView> { Title = "Description", Value = l => l.Description },
            new DataTableColumn<EventListenerView> { Title = "Handler", Value = l => l.HandlerName },
        };

        try
        {
            var addresses = await AddressesViewService.RetrieveAllAddressesAsync();
            address = addresses.FirstOrDefault(item => item.Id == AddressId);

            if (address is not null)
            {
                await LoadListenersAsync();
            }
        }
        catch
        {
            errorMessage = "Unable to load this address. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadListenersAsync()
    {
        try
        {
            listeners = await ListenersViewService.RetrieveListenersByAddressAsync(AddressId);
            listenersError = null;
        }
        catch
        {
            listenersError = "Unable to load listeners.";
        }
    }

    private void RequestDeleteAddress()
    {
        deleteError = null;
        confirmVisible = true;
    }

    private void CancelDelete() =>
        confirmVisible = false;

    private async Task DeleteAddressAsync()
    {
        confirmVisible = false;

        try
        {
            await AddressesViewService.RemoveAddressByIdAsync(AddressId);
            Navigation.NavigateTo("admin/event-addresses");
        }
        catch
        {
            deleteError =
                "Unable to delete this address. It may still have events or listeners associated with it.";
        }
    }
}
