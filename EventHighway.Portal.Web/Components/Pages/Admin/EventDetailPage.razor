@page "/admin/events/{EventId:guid}"
@attribute [Authorize(Roles = "Administrators")]
@using System.Collections.Generic
@using System.Linq
@using System.Text.Json
@using EventHighway.Portal.Web.Components.CoreUI
@using EventHighway.Portal.Web.Models.Views.Events
@using EventHighway.Portal.Web.Models.Views.ListenerEvents
@using EventHighway.Portal.Web.Services.Views.Events
@using EventHighway.Portal.Web.Services.Views.ListenerEvents
@inject IEventsViewService EventsViewService
@inject IListenerEventsViewService ListenerEventsViewService

<PageTitle>Event</PageTitle>

<div class="d-flex justify-content-between align-items-center py-3">
    <h2 class="mb-0">Event</h2>
    <a class="btn btn-outline-secondary btn-sm" href="admin/events">Back to list</a>
</div>

@if (isLoading)
{
    <Spinner />
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}
else if (eventView is not null)
{
    <Card>
        <HeaderContent>
            <div class="d-flex justify-content-between align-items-center w-100">
                <span class="fw-semibold">Event</span>
                <span class="badge @StatusCssClass">@eventView.Status</span>
            </div>
        </HeaderContent>
        <ChildContent>
            <dl class="row mb-0">
                <dt class="col-sm-3">Id</dt>
                <dd class="col-sm-9">@eventView.Id</dd>

                <dt class="col-sm-3">Event Name</dt>
                <dd class="col-sm-9">@DisplayOrDash(eventView.EventName)</dd>

                <dt class="col-sm-3">Content</dt>
                <dd class="col-sm-9">
                    @if (string.IsNullOrWhiteSpace(eventView.Content))
                    {
                        <span>—</span>
                    }
                    else
                    {
                        <Button Color="outline-primary" CssClass="btn-sm"
                                OnClick="() => showContent = true">
                            View Content
                        </Button>
                    }
                </dd>

                <dt class="col-sm-3">Type</dt>
                <dd class="col-sm-9">@eventView.Type</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@eventView.Status</dd>

                <dt class="col-sm-3">Retries Left</dt>
                <dd class="col-sm-9">@eventView.RemainingRetryAttempts</dd>

                <dt class="col-sm-3">Event Address Id</dt>
                <dd class="col-sm-9">@eventView.EventAddressId</dd>

                <dt class="col-sm-3">Event Address</dt>
                <dd class="col-sm-9">@DisplayOrDash(eventView.EventAddressName)</dd>

                <dt class="col-sm-3">Participant Id</dt>
                <dd class="col-sm-9">@(eventView.ParticipantId?.ToString() ?? "—")</dd>

                <dt class="col-sm-3">Scheduled</dt>
                <dd class="col-sm-9">@(eventView.ScheduledDate?.ToString("u") ?? "—")</dd>

                <dt class="col-sm-3">Created</dt>
                <dd class="col-sm-9">@eventView.CreatedDate.ToString("u")</dd>
            </dl>
        </ChildContent>
    </Card>

    <Card CssClass="mt-4">
        <HeaderContent>
            <span class="fw-semibold">Dispatched listener events</span>
        </HeaderContent>
        <ChildContent>
            @if (listenerEvents.Count == 0)
            {
                <p class="text-body-secondary mb-0">No events dispatched yet.</p>
            }
            else
            {
                <DataTable TItem="ListenerEventView" Items="FilteredListenerEvents"
                           Columns="listenerColumns" Searchable="true"
                           RowClass="@(e => e.Status == "Success" ? "table-success"
                               : e.Status == "Error" ? "table-danger"
                               : null)">
                    <ExtraFilters>
                        <select class="form-select w-auto" value="@selectedListenerStatus"
                                @onchange="e => { selectedListenerStatus = e.Value?.ToString() ?? string.Empty; }">
                            <option value="">All Statuses</option>
                            <option value="Pending">Pending</option>
                            <option value="Success">Success</option>
                            <option value="Error">Error</option>
                            <option value="Replay">Replay</option>
                        </select>
                    </ExtraFilters>
                </DataTable>
            }
        </ChildContent>
    </Card>

    <Modal Title="Event Content" Size="xl" Scrollable="true"
           Visible="showContent" OnClose="() => showContent = false">
        <ChildContent>
            <div class="overflow-auto">
                <pre class="mb-0">@FormattedContent</pre>
            </div>
        </ChildContent>
        <FooterContent>
            <Button Color="secondary" OnClick="() => showContent = false">Close</Button>
        </FooterContent>
    </Modal>
}
else
{
    <div class="alert alert-warning" role="alert">Event not found.</div>
}

@code {
    [Parameter]
    public Guid EventId { get; set; }

    private bool isLoading = true;
    private string? errorMessage;
    private EventView? eventView;
    private List<ListenerEventView> listenerEvents = new();
    private List<DataTableColumn<ListenerEventView>> listenerColumns = new();
    private string selectedListenerStatus = string.Empty;
    private bool showContent;

    private List<ListenerEventView> FilteredListenerEvents =>
        string.IsNullOrEmpty(selectedListenerStatus)
            ? listenerEvents
            : listenerEvents.Where(e => e.Status == selectedListenerStatus).ToList();

    // Pretty-prints the payload as indented JSON; falls back to the raw string when it
    // isn't valid JSON so non-JSON content is still viewable.
    private string FormattedContent
    {
        get
        {
            string content = eventView?.Content ?? string.Empty;

            if (string.IsNullOrWhiteSpace(content))
            {
                return string.Empty;
            }

            try
            {
                using JsonDocument document = JsonDocument.Parse(content);

                return JsonSerializer.Serialize(
                    document.RootElement,
                    new JsonSerializerOptions { WriteIndented = true });
            }
            catch (JsonException)
            {
                return content;
            }
        }
    }

    private string StatusCssClass =>
        eventView?.Status switch
        {
            "Active" => "text-bg-success",
            "Quarantined" => "text-bg-warning",
            _ => "text-bg-secondary"
        };

    protected override async Task OnInitializedAsync()
    {
        listenerColumns = new List<DataTableColumn<ListenerEventView>>
        {
            new DataTableColumn<ListenerEventView> { Title = "Id", Value = e => e.Id },
            new DataTableColumn<ListenerEventView>
            {
                Title = "Status",
                Value = e => e.Status,
                CellTemplate = e =>
                    @<span class="badge @(e.Status == "Success" ? "text-bg-success"
                        : e.Status == "Error" ? "text-bg-danger"
                        : "text-bg-secondary")">@e.Status</span>
            },
            new DataTableColumn<ListenerEventView>
            {
                Title = "Response Code", Value = e => e.ResponseCode
            },
            new DataTableColumn<ListenerEventView>
            {
                Title = "Response Message", Value = e => e.ResponseMessage
            },
            new DataTableColumn<ListenerEventView>
            {
                Title = "Listener", Value = e => e.EventListenerId
            },
            new DataTableColumn<ListenerEventView>
            {
                Title = "Listener Name", Value = e => e.ListenerName ?? "—"
            },
            new DataTableColumn<ListenerEventView>
            {
                Title = "Created", Value = e => e.CreatedDate.ToString("u")
            },
        };

        try
        {
            eventView = await EventsViewService.RetrieveEventByIdAsync(EventId);

            if (eventView is not null)
            {
                listenerEvents =
                    await ListenerEventsViewService.RetrieveListenerEventsByEventIdAsync(EventId);
            }
        }
        catch
        {
            errorMessage = "Unable to load this event. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string DisplayOrDash(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "—" : value;
}
